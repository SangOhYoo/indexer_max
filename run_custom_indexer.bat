echo  1) 특정 카테고리를 강제 인덱싱할 때 (기본)
echo     python indexer_max.py -b jp -c "아내의기쁨" -f
echo.
echo  2) 특정 일자 범위를 지정해서 강제 인덱싱할 때 (from ~ to)
echo     python indexer_max.py -b jp -c "아내의기쁨" -f -s "2026-06-01" -e "2026-06-15"
echo.
echo  3) 특정 일자 이후의 데이터만 강제 인덱싱할 때 (from ~ 현재)
