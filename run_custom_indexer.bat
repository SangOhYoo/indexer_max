@echo off
chcp 65001 > nul
echo =======================================================
echo          파이썬 인덱서 수동 실행 배치 파일
echo =======================================================
echo.
echo [사용 방법]
echo 다음 줄의 코드를 직접 수정하여 원하는 작업을 지정하세요.
echo.
echo  -b : 작업할 게시판 이름 (예: jp)
echo  -c : 카테고리 이름 (예: "아내의기쁨") ※ 띄어쓰기가 있다면 따옴표 포함
echo  -f : 강제 재작업 옵션 (시간 상관없이 강제 삭제 및 재입력. 필요 없으면 -f 지울 것)
echo  -s : 시작 일자 (예: 2026-06-01 또는 2026-06-01 12:00:00)
